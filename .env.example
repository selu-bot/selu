# Selu Orchestrator – Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
# 32-byte base64-encoded AES key for encrypting stored credentials.
# Generate with: openssl rand -base64 32
SELU__ENCRYPTION_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# SELU__SERVER__HOST=0.0.0.0
# SELU__SERVER__PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# SELU__DATABASE__URL=sqlite://selu.db?mode=rwc

# ── Agents ───────────────────────────────────────────────────────────────────
# SELU__INSTALLED_AGENTS_DIR=./installed_agents
# SELU__MARKETPLACE_URL=https://selu.bot/api/marketplace/agents

# ── Capability containers ────────────────────────────────────────────────────
# SELU__EGRESS_PROXY_ADDR=0.0.0.0:8888

# ── Event system ─────────────────────────────────────────────────────────────
# SELU__MAX_CHAIN_DEPTH=3

# ── Agent tool loop ──────────────────────────────────────────────────────────
# SELU__MAX_TOOL_LOOP_ITERATIONS=32

# ── System updates ───────────────────────────────────────────────────────────
# SELU__RELEASE_METADATA_URL=https://selu.bot/api/releases/selu
# SELU__UPDATER_URL=http://selu-updater:8090
# SELU__UPDATER_SHARED_SECRET=
# SELU__UPDATER_REQUEST_TIMEOUT_SECS=30

# Updater sidecar: WhatsApp bridge management
# UPDATER__WHATSAPP_BRIDGE_ENABLED=true
# UPDATER__WHATSAPP_BRIDGE_IMAGE_REPO=ghcr.io/selu-bot/selu-whatsapp-bridge
# UPDATER__WHATSAPP_BRIDGE_CONTAINER_NAME=selu-whatsapp-bridge
# UPDATER__WHATSAPP_BRIDGE_DATA_VOLUME=selu-whatsapp-bridge-data
# UPDATER__WHATSAPP_BRIDGE_NETWORK=                  # optional: auto-detected when empty
# UPDATER__WHATSAPP_BRIDGE_PORT=3200
