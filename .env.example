# Selu Orchestrator – Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
# 32-byte base64-encoded AES key for encrypting stored credentials.
# Generate with: openssl rand -base64 32
SELU__ENCRYPTION_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# SELU__SERVER__HOST=0.0.0.0
# SELU__SERVER__PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# SELU__DATABASE__URL=sqlite://selu.db?mode=rwc

# ── Agents ───────────────────────────────────────────────────────────────────
# SELU__AGENTS_DIR=./agents

# ── Capability containers ────────────────────────────────────────────────────
# SELU__EGRESS_PROXY_ADDR=0.0.0.0:8888

# ── Event system ─────────────────────────────────────────────────────────────
# SELU__MAX_CHAIN_DEPTH=3

# ── Semantic memory (optional) ───────────────────────────────────────────────
# Enables embedding-based recall for the default agent.
# Requires an OpenAI-compatible embedding API key.
# SELU__EMBEDDING__API_KEY=sk-...
# SELU__EMBEDDING__BASE_URL=https://api.openai.com
# SELU__EMBEDDING__MODEL=text-embedding-3-small
