# PAP Orchestrator – Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────
# 32-byte base64-encoded AES key for encrypting stored credentials.
# Generate with: openssl rand -base64 32
PAP__ENCRYPTION_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# PAP__SERVER__HOST=0.0.0.0
# PAP__SERVER__PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# PAP__DATABASE__URL=sqlite://pap.db?mode=rwc

# ── Agents ───────────────────────────────────────────────────────────────────
# PAP__AGENTS_DIR=./agents

# ── Capability containers ────────────────────────────────────────────────────
# PAP__EGRESS_PROXY_ADDR=0.0.0.0:8888

# ── Event system ─────────────────────────────────────────────────────────────
# PAP__MAX_CHAIN_DEPTH=3

# ── Semantic memory (optional) ───────────────────────────────────────────────
# Enables embedding-based recall for the default agent.
# Requires an OpenAI-compatible embedding API key.
# PAP__EMBEDDING__API_KEY=sk-...
# PAP__EMBEDDING__BASE_URL=https://api.openai.com
# PAP__EMBEDDING__MODEL=text-embedding-3-small
