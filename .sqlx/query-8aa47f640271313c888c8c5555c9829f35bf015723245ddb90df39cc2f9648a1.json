  "query": "SELECT wc.id as config_id, wc.pipe_id, p.inbound_token, p.outbound_auth\n           FROM whatsapp_configs wc\n           JOIN pipes p ON p.id = wc.pipe_id\n           WHERE wc.active = 1 AND p.active = 1\n           ORDER BY wc.created_at DESC\n           LIMIT 1",
